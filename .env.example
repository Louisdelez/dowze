# ─────────────────────────────────────────────────────────────
#  Dowze — variables d'environnement (exemple)
#  Copier en `.env` (NE JAMAIS committer le `.env` réel).
#  Les valeurs ci-dessous sont celles par défaut de `supabase start` (local).
# ─────────────────────────────────────────────────────────────

# ── Supabase (local) ──
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=                       # affiché par `supabase start`
SUPABASE_SERVICE_ROLE_KEY=               # BACKEND UNIQUEMENT — jamais côté navigateur
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Web (Next.js) ── (les NEXT_PUBLIC_* sont exposées au navigateur)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# ── API (NestJS) ──
API_PORT=3001
REDIS_URL=redis://127.0.0.1:6379
