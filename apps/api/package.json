{
  "name": "@dowze/api",
  "version": "2.22.0",
  "private": true,
  "description": "Backend NestJS de Dowze (l'intra-core) : graphe de compétences, pont .json, progression, planning.",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@dowze/core": "*",
    "@dowze/schemas": "*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "drizzle-orm": "^0.45.2",
    "jose": "^5.9.6",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uid": "2.0.2",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
