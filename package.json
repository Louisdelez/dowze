{
  "name": "dowze",
  "version": "2.20.0",
  "private": true,
  "description": "Dowze — système d'éducation 2.0 en bien commun. Monorepo (web + api + packages).",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "license": "MIT",
  "author": "Louis Delez",
  "repository": {
    "type": "git",
    "url": "https://github.com/Louisdelez/dowze.git"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"apps/**/*.{ts,tsx,css,json}\" \"packages/**/*.{ts,json}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,css,json}\" \"packages/**/*.{ts,json}\"",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
